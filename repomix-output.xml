      return rawDistance;
    }

    if (typeof rawDistance === "string" && rawDistance.trim()) {
      const parsed = Number(rawDistance.replace(/[\sкмKM]+/g, ""));
      if (Number.isFinite(parsed) && parsed > 0) return parsed;
    }

