# ─── CargoFlow — Environment Variables ────────────────────────
# Скопируйте: cp .env.example .env

# Supabase (Self-Hosted или Cloud)
SUPABASE_URL=https://<your-supabase-host>
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_EMAIL=<service-account-email>
SUPABASE_SERVICE_PASSWORD=<service-account-password>

# OpenRouter — ИИ-аудит рейсов (опционально)
OPENROUTER_API_KEY=<your-openrouter-api-key>

# JWT — секрет для подписи токенов (минимум 32 символа)
JWT_SECRET=<random-secret-min-32-chars>

# Режим работы: development | production
APP_ENV=development
BACKEND_PORT=8000

# CORS
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000
